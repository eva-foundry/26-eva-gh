# Nested git repos - tracked as reference copies, not submodules
# Individual repos already have their own .gitignore files

# Node (from nested repos)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Python (from nested repos)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Build outputs
dist/
build/
.next/
out/

# OS / IDE
.DS_Store
Thumbs.db
*.log
