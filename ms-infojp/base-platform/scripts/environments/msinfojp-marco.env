# MS-InfoJP Environment Configuration for MarcoSub
# Using EXISTING ao-sandbox Azure OpenAI resource
# Created: 2026-01-25

# Azure Subscription Configuration
export LOCATION="canadacentral"
export WORKSPACE="msinfojp-marco"
export SUBSCRIPTION_ID="c59ee575-eb2a-4b51-a865-4b618f9add0a"

# Feature Flags (MVP Configuration)
export AZURE_ENVIRONMENT="AzureCloud"
export SECURE_MODE=false
export ENABLE_WEB_CHAT=false
export ENABLE_BING_SAFE_SEARCH=true
export ENABLE_UNGROUNDED_CHAT=true
export ENABLE_MATH_ASSISTANT=false
export ENABLE_TABULAR_DATA_ASSISTANT=false
export ENABLE_SHAREPOINT_CONNECTOR=false
export SHAREPOINT_TO_SYNC=""

# Security & Auth
export REQUIRE_WEBSITE_SECURITY_MEMBERSHIP=false
export SECRET_EXPIRATION_DAYS=730

# Use EXISTING ao-sandbox Azure OpenAI
export USE_EXISTING_AOAI=true
export AZURE_OPENAI_RESOURCE_GROUP="rg-sandbox"
export AZURE_OPENAI_SERVICE_NAME="ao-sandbox"
export AZURE_OPENAI_CHATGPT_DEPLOYMENT="gpt-4o"

# Use existing text-embedding-3-small (BETTER than ada-002!)
export USE_AZURE_OPENAI_EMBEDDINGS=true
export AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME="text-embedding-3-small"

# Model Configuration (ao-sandbox is in eastus)
export AZURE_OPENAI_CHATGPT_MODEL_NAME="gpt-4o"
export AZURE_OPENAI_CHATGPT_MODEL_VERSION="2024-08-06"
export AZURE_OPENAI_CHATGPT_SKU="Standard"
export AZURE_OPENAI_EMBEDDINGS_MODEL_NAME="text-embedding-3-small"
export AZURE_OPENAI_EMBEDDINGS_MODEL_VERSION="1"
export AZURE_OPENAI_EMBEDDINGS_SKU="Standard"
export AZURE_OPENAI_CHATGPT_MODEL_CAPACITY=20
export AZURE_OPENAI_EMBEDDINGS_MODEL_CAPACITY=150

# Application Config
export CHAT_WARNING_BANNER_TEXT=""
export DEFAULT_LANGUAGE="en-US"
export ENABLE_CUSTOMER_USAGE_ATTRIBUTION=false
export CUSTOMER_USAGE_ATTRIBUTION_ID=""
export APPLICATION_TITLE="MS-InfoJP: Jurisprudence Assistant"
export ENABLE_DEV_CODE=true
export MAX_CSV_FILE_SIZE=20

# Entra/AD
export ENTRA_OWNERS=""
export SERVICE_MANAGEMENT_REFERENCE=""
export PASSWORD_LIFETIME=365

# Network (not used in non-secure mode)
export ENABLE_DDOS_PROTECTION_PLAN=false

# ===== SANDBOX SKU OVERRIDES (Minimal Cost for 3GB data, 1-2 users) =====
export TF_VAR_appServiceSkuSize="B1"
export TF_VAR_appServiceSkuTier="Basic"
export TF_VAR_enrichmentAppServiceSkuSize="B1"
export TF_VAR_enrichmentAppServiceSkuTier="Basic"
export TF_VAR_functionsAppSkuSize="B1"
export TF_VAR_functionsAppSkuTier="Basic"
export TF_VAR_searchServicesSkuName="basic"
